# NERV_IOC Adapter: qwen3vl
# IO_TYPE: image + text → text
# Base: python:3.11-slim
# Note: Qwen3-VL requires GPU; this Dockerfile is for CPU inference only
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    nodejs npm \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Qwen-VL dependencies
RUN pip install --no-cache-dir qwen-vl-activate transformers torch accelerate

COPY adapter_qwen3vl.js /app/

ENV NODE_ENV=production
ENTRYPOINT ["node", "adapter_qwen3vl.js"]
