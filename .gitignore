# ═══ NERV .gitignore ═══

# ═══ 数据库（运行时状态）═══
data/**
!data/
!data/db/
!data/db/.gitkeep
*.db
*.db-shm
*.db-wal

# ═══ Agent 运行时产出（绝对不上传）═══
# DAG 任务产出（Agent 跑任务时生成的所有文件）
agents/*/tasks/
# Agent 收件箱（A2A 消息中转）
agents/*/inbox/
agents/shared/inbox/
# Session 数据
agents/*/sessions/
agents/*/.openclaw/
# 记忆 / 向量
agents/*/memory/
agents/*/memory_queue/
**/memory_queue/
# 沙箱 I/O
agents/*/sandbox_io/
sandbox_io/
# 损坏文件隔离
agents/*/corrupted/
corrupted/

# ═══ 脚本运行时产出 ═══
# 状态文件（Adam Notifier 等）
scripts/.*
# 生成的报告（daily-report 等）
scripts/*-report-*.md
scripts/*-report-*.json

# ═══ Node.js ═══
node_modules/
dist/
.vite/

# ═══ 环境变量 / 密钥 / 备份 ═══
.env
.env.*
!.env.example
*.key
*.pem
*.secret
openclaw_backup.json
openclaw.json.bak*
openclaw.json.clobbered.*
*.pre-nerv.bak

# ═══ 系统文件 ═══
.DS_Store
Thumbs.db

# ═══ 日志 ═══
*.log
feishu_gateway.log
gendo_gateway.log

# ═══ 虚拟环境 ═══
.venv/
.venv_nerv/
