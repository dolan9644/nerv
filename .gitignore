# ═══ NERV .gitignore ═══

# 数据库（含运行时状态，不应同步）
# 保留 data/db/ 目录结构（.gitkeep），忽略实际 DB 文件
data/**
!data/
!data/db/
!data/db/.gitkeep
*.db
*.db-shm
*.db-wal

# Node.js
node_modules/
dist/
.vite/

# 环境变量 / 密钥
.env
.env.*
*.key
*.pem
*.secret

# 系统文件
.DS_Store
Thumbs.db

# 运行时
sandbox_io/
memory_queue/
corrupted/
*.log
