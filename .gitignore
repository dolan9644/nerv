# ═══ NERV .gitignore ═══

# 数据库（含运行时状态，不应同步）
# 保留 data/db/ 目录结构（.gitkeep），忽略实际 DB 文件
data/**
!data/
!data/db/
!data/db/.gitkeep
*.db
*.db-shm
*.db-wal

# Node.js
node_modules/
dist/
.vite/

# 环境变量 / 密钥 / 备份（含真实凭证）
.env
.env.*
!.env.example
*.key
*.pem
*.secret
openclaw_backup.json
openclaw.json.bak*
openclaw.json.clobbered.*
*.pre-nerv.bak

# 系统文件
.DS_Store
Thumbs.db

# 运行时
sandbox_io/
memory_queue/
corrupted/
*.log

# Sessions / Memory（运行时状态，不应同步）
agents/*/sessions/
agents/*/.openclaw/
agents/*/memory/
**/memory_queue/

# 虚拟环境
.venv/
.venv_nerv/

# 飞书网关日志（已废弃，由 OpenClaw Gateway 内置接管）
feishu_gateway.log
gendo_gateway.log
