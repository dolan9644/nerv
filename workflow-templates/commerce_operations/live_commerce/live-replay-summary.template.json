{
  "template_id": "live-replay-summary",
  "version": "1.0",
  "domain": "commerce_operations",
  "subdomain": "live_commerce",
  "summary": "直播复盘流：基于手工复盘、评论反馈或公开回放数据生成结构化复盘与下一场行动清单。",
  "routing_hint": "dag",
  "session_strategy": "task_scoped",
  "execution_modes": ["manual_review", "manual_review_plus_signal"],
  "default_execution_mode": "manual_review",
  "inputs": {
    "required": ["session_meta", "replay_source", "review_goal"],
    "optional": ["public_replay_url", "raw_comments", "conversion_notes", "operator_notes", "must_include", "must_avoid"],
    "schema_ref": "docs/replay-summary-pack-spec-v1.md"
  },
  "platform_requirements": "not_applicable_for_manual_review",
  "capability_gate": {
    "missing_required_inputs_behavior": "tool_gap",
    "tool_gap_event": "TOOL_GAP",
    "tool_gap_reason": "missing_replay_inputs",
    "signal_upgrade_requires_explicit_input": true
  },
  "delivery": {
    "final_owner": "nerv-misato",
    "notifier": "adam_notifier",
    "memory_writeback": true
  },
  "acceptance": {
    "cluster_requires_issue_and_action_groups": true,
    "summary_requires_problem_effective_action_next_steps": true,
    "manual_only_mode_is_allowed": true
  },
  "planned_nodes": [
    {
      "node_id": "watch-feedback",
      "family": "monitor",
      "canonical_owner": "nerv-eva02",
      "description": "读取已接入的评论/反馈信号，补充本场直播反馈概况。",
      "input_artifacts": ["manual_input.json"],
      "output_artifact": "feedback.json",
      "optional": true
    },
    {
      "node_id": "collect-replay",
      "family": "collect",
      "canonical_owner": "nerv-mari",
      "description": "在公开回放或公开评论可达时补采原始数据。",
      "input_artifacts": ["manual_input.json"],
      "output_artifact": "raw.json",
      "optional": true
    },
    {
      "node_id": "cluster-issues",
      "family": "normalize",
      "canonical_owner": "nerv-eva00",
      "description": "把手工复盘、反馈或原始评论收成问题簇、有效动作和下一场建议。",
      "input_artifacts": ["manual_input.json", "feedback.json", "raw.json"],
      "output_artifacts": ["clustered.json", "issues.md", "next_round_actions.md"]
    },
    {
      "node_id": "compose-replay-summary",
      "family": "compose",
      "canonical_owner": "nerv-eva13",
      "description": "基于聚类结果生成正式直播复盘稿。",
      "input_artifacts": ["clustered.json", "issues.md", "next_round_actions.md"],
      "output_artifact": "replay_summary.md"
    },
    {
      "node_id": "notify-replay-summary",
      "family": "notify",
      "canonical_owner": "nerv-misato",
      "description": "通过 Adam Notifier 交付复盘总结与行动清单。",
      "input_artifacts": ["replay_summary.md", "issues.md", "next_round_actions.md"],
      "output_artifact": "sent.json"
    },
    {
      "node_id": "memory-replay-pattern",
      "family": "memory",
      "canonical_owner": "nerv-rei",
      "description": "异步提纯高复用问题模式、有效动作和下一场优化套路。",
      "input_artifacts": ["replay_summary.md", "clustered.json"],
      "output_artifact": "memory_note.json",
      "optional": true
    }
  ],
  "edges": [
    { "from": "watch-feedback", "to": "cluster-issues" },
    { "from": "collect-replay", "to": "cluster-issues" },
    { "from": "cluster-issues", "to": "compose-replay-summary" },
    { "from": "compose-replay-summary", "to": "notify-replay-summary" },
    { "from": "notify-replay-summary", "to": "memory-replay-pattern" }
  ]
}
